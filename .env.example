# Environment Variables for Render Deployment
# Copy this file and set these variables in Render Dashboard → Environment

# Database URL (provided by Render PostgreSQL)
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=your_internal_database_url_from_render

# Django Secret Key (generate a new one - do not use the one in settings.py)
# Generate with: python manage.py shell
# >>> from django.core.management.utils import get_random_secret_key
# >>> print(get_random_secret_key())
SECRET_KEY=your_generated_secret_key_here

# Debug Mode (set to False in production)
DEBUG=False

# Python Version (for Render)
PYTHON_VERSION=3.10.0

# Optional: Custom admin credentials (if not set, defaults to admin/admin123)
# ADMIN_USERNAME=admin
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your_secure_password_here

# Optional: Disable initial setup page after first admin is created
# DISABLE_SETUP=True

# Optional: Additional environment variables you might need
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-email-password
