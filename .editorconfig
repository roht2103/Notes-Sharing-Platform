# EditorConfig helps maintain consistent coding styles
root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Python files
[*.py]
indent_style = space
indent_size = 4

# HTML/Django templates - DO NOT AUTO-FORMAT
[*.html]
indent_style = space
indent_size = 2
# Disable auto-formatting for Django templates
max_line_length = off

# CSS files
[*.css]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
